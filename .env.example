# Copy this file to `.env` and fill in your real keys.
# `.env` is gitignored.

# DeepSeek API（OpenAI 兼容接口）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 可选：Semantic Scholar API Key（提高速率限制，未填则匿名调用）
SEMANTIC_SCHOLAR_API_KEY=

# 可选：Unpaywall 需要一个 email 作为标识
UNPAYWALL_EMAIL=you@example.com

# 输出目录
OUTPUT_DIR=./outputs

# 重试次数（LLM 输出字段不全时）
MAX_RETRIES=2

# 单篇论文 LLM 调用的 token 上限（粗略控制 chunking）
MAX_INPUT_TOKENS=12000

# 是否缓存下载的 PDF 到 .cache/pdfs/（true/false）
# 开启后，相同 arXiv id / DOI 重跑会复用本地文件，省带宽与时间。
# 关闭则用临时文件，解析完即删。
ENABLE_PDF_CACHE=true
